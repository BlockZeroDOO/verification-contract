receipt.denotary.io {
    encode gzip zstd
    tls {
        issuer acme
    }

    @receipts path /v1/receipts/*
    handle @receipts {
        reverse_proxy 127.0.0.1:8082
    }
}

audit.denotary.io {
    encode gzip zstd
    tls {
        issuer acme
    }

    @audit path /v1/audit/* /healthz /openapi.json /docs
    handle @audit {
        reverse_proxy 127.0.0.1:8083
    }
}

# The finality watcher remains private and should not be routed publicly.
